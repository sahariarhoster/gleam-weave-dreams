{
  "manifest_version": 3,
  "name": "WA Suite — WhatsApp Contact Exporter",
  "version": "1.0.2",
  "description": "Export all contacts from your WhatsApp Web chat list as CSV.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
